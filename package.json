{
  "name": "backend-challenge",
  "version": "1.0.0",
  "description": "Backend Challenge - Unique",
  "author": "John ALLOU",
  "private": true,
  "license": "Unique",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:local": "dotenv -e ./.env.local -- nest start",
    "start:dev": "nest start --watch",
    "start:dev:local": "dotenv -e ./.env.local -- nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "docker:init": "npm run prisma:migrate:deploy && npm run prisma:seed:docker",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest --runInBand --detectOpenHandles",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "prisma:generate": "dotenv -e ./.env -- prisma generate",
    "prisma:generate:local": "dotenv -e ./.env.local -- prisma generate",
    "prisma:migrate": "dotenv -e ./.env -- prisma migrate dev",
    "prisma:migrate:local": "dotenv -e ./.env.local -- prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:seed": "dotenv -e ./.env -- prisma db seed",
    "prisma:seed:local": "dotenv -e ./.env.local -- prisma db seed",
    "prisma:seed:docker": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anchan828/nest-redlock": "^0.4.1",
    "@apollo/server": "^4.12.2",
    "@nestjs/apollo": "^12.2.2",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/graphql": "^12.2.2",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/schedule": "^4.0.0",
    "@prisma/adapter-pg": "^7.0.1",
    "@prisma/client": "^7.0.0",
    "async-retry": "^1.3.3",
    "cuid": "^2.1.8",
    "date-fns": "^3.0.0",
    "graphql": "^16.12.0",
    "ioredis": "^5.3.0",
    "nestjs-pino": "^4.5.0",
    "pg": "^8.16.3",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@swc/cli": "^0.4.0",
    "@swc/core": "^1.10.8",
    "@types/async-retry": "^1.4.8",
    "@types/express": "^4.17.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "dotenv-cli": "^8.0.0",
    "eslint": "^8.50.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.7.0",
    "pino-pretty": "^13.1.2",
    "prettier": "^3.0.0",
    "prisma": "^7.0.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.3.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.ts$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
